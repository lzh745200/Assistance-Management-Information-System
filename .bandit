[bandit]
# 帮扶管理信息系统 安全扫描配置（bandit）
# 跳过测试场景下合理的规则：
#   B101  assert 用法（测试中大量使用）
#   B311  random 用于非加密场景（伪随机数生成业务数据）
#   B601  paramiko 自动加载（本项目不使用，避免误报）
#   B602  subprocess shell=True（受控调用场景）
skips = B101,B311,B601,B602
tests_dirs = tests
exclude_dirs = .venv,venv,build,dist,artifacts,backend/build

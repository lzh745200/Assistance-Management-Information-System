# 帮扶管理信息系统 - 环境变量配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 基础配置 ====================
PROJECT_NAME=帮扶管理信息系统
PROJECT_VERSION=1.4.1
API_PREFIX=/api/v1
DEBUG=false
ENVIRONMENT=development

# ==================== 加密密钥配置 ====================
# ⚠️ 安全警告：生产环境必须修改默认密钥！
# 推荐使用加密存储来保护敏感密钥
# 1. 运行密钥迁移工具: python -m backend.app.utils.secret_migration
# 2. 启用加密密钥: USE_ENCRYPTED_SECRETS=true
# 3. 密钥将从 backend/secrets/encrypted_config.json 加载
USE_ENCRYPTED_SECRETS=false
SECRETS_FILE_PATH=./backend/secrets/encrypted_config.json
MASTER_KEY_PATH=./backend/secrets/master.key

# ⚠️⚠️⚠️ 严禁在 .env 中填入占位符或提交真实密钥 ⚠️⚠️⚠️
# 留空 = 由 backend/app/utils/runtime_secrets.py 自动生成并持久化到
#        backend/data/runtime_secrets.json（仅在文件 0o600 权限下安全）
# 推荐：生产环境使用 USE_ENCRYPTED_SECRETS=true 走加密文件加载
# ⚠️ 警告：不要在生产环境使用默认值！
# ⚠️ 警告：不要将实际密钥提交到版本控制系统！
# 注意：启用 USE_ENCRYPTED_SECRETS 后，这些值将被加密文件中的值覆盖
SECRET_KEY=
CSRF_SECRET_KEY=
ALGORITHM=HS256

# ==================== 数据库配置 ====================
DATABASE_URL=sqlite:///./data/rural_revitalization.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false
SLOW_QUERY_THRESHOLD_MS=500.0

# ==================== 服务器配置 ====================
# ⚠️ 离线单机部署默认 127.0.0.1。多机网络部署才改为 0.0.0.0 + 防火墙策略
HOST=127.0.0.1
PORT=8000

# ==================== 缓存配置 ====================
CACHE_DIR=./data/cache
CACHE_SIZE_LIMIT=100
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=3600
CACHE_MAX_SIZE=10000

# ==================== 安全配置 ====================
# token 有效期：军用安全基线要求 ≤8h（480 分钟）。代码默认 480；此处可按部署环境收窄。
# 结合 token_version 强制下线可进一步缓解会话泄露风险。
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7
BCRYPT_ROUNDS=12
PASSWORD_EXPIRE_DAYS=90
MAX_FAILED_LOGIN_ATTEMPTS=10
ACCOUNT_LOCKOUT_MINUTES=30

# ==================== CORS配置 ====================
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# ==================== CSRF配置 ====================
# 默认开启（军用安全基线）。前端 request.ts 自动获取并回填 X-CSRF-Token。
# 调试时可设为 false 临时关闭。
CSRF_ENABLED=true

# ==================== 速率限制 ====================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_FORMAT=json
LOG_ROTATION=10 days
LOG_RETENTION=30 days
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5

# ==================== 文件上传配置 ====================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=xlsx,xls,csv,pdf,jpg,jpeg,png,doc,docx,pptx

# ==================== 监控配置 ====================
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true

# ==================== 告警配置 ====================
# 邮件告警配置
ALERT_EMAIL_RECIPIENTS=admin@example.com,ops@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@example.com

# Webhook告警配置
ALERT_WEBHOOK_URL=https://your-webhook-url.com/alert
ALERT_WEBHOOK_TYPE=generic  # 可选: generic, dingtalk, wecom

# ==================== 数据库迁移配置 ====================
ENABLE_AUTO_MIGRATION=true

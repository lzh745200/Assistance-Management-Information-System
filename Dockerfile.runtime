# ============================================================
# 军队乡村振兴管理系统 — 生产运行时 Docker 镜像
# 用途: 在容器中运行完整的 Web 应用（FastAPI + Vue3 前端）
# 构建: docker build -f Dockerfile.runtime -t mrrms:latest .
# 运行: docker run -p 8000:8000 -v ./data:/app/data mrrms:latest
# ============================================================

# ─── Stage 1: 前端构建 ───
FROM node:20-alpine AS frontend-builder

WORKDIR /src/frontend

COPY frontend/package.json frontend/package-lock.json* ./
RUN npm ci 2>/dev/null || npm install

COPY frontend/ ./
RUN npm run build

# ─── Stage 2: 运行时 ───
FROM python:3.11-slim-bookworm AS runtime

LABEL org.opencontainers.image.title="Military Rural Revitalization Management System"
LABEL org.opencontainers.image.description="军队乡村振兴管理系统 - 离线桌面应用 Web 版"
LABEL org.opencontainers.image.version="1.3.0"

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    HOST=0.0.0.0 \
    PORT=8000 \
    ENV=production

# 安装系统依赖
RUN apt-get update && apt-get install -y --no-install-recommends \
    libmagic1 \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd --create-home --shell /bin/bash app

WORKDIR /app

# 安装 Python 依赖（先复制 requirements 以利用 Docker 缓存）
COPY backend/requirements.txt backend/requirements-prod.txt* ./
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./

# 复制前端构建产物
COPY --from=frontend-builder /src/frontend/dist/ ./resources/frontend/

# 复制启动脚本
COPY launch.py ./

# 创建数据目录并设置权限
RUN mkdir -p /app/data /app/logs /app/uploads /app/exports /app/backups && \
    chown -R app:app /app

# 切换到非 root 用户
USER app

# 健康检查
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

EXPOSE 8000

# 启动命令
CMD ["python", "start.py"]

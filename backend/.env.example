# 帮扶管理信息系统 — 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# 警告：请勿将 .env 文件提交到版本控制系统

# ========== 安全密钥 ==========
SECRET_KEY=your-secret-key-here-change-in-production
CSRF_SECRET_KEY=your-csrf-secret-key-here-change-in-production

# ========== 数据库 ==========
DATABASE_URL=sqlite:///./data/rural_revitalization.db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=False
DB_ENCRYPTION_ENABLED=False

# ========== 服务器 ==========
HOST=127.0.0.1
PORT=8000
DEBUG=False
ENVIRONMENT=production
API_PREFIX=/api/v1

# ========== 认证 ==========
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=30
BCRYPT_ROUNDS=12
PASSWORD_EXPIRE_DAYS=90
MAX_FAILED_LOGIN_ATTEMPTS=5
ACCOUNT_LOCKOUT_MINUTES=30

# ========== CORS ==========
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization,X-Requested-With

# ========== CSRF ==========
CSRF_ENABLED=True

# ========== 速率限制 ==========
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ========== 日志 ==========
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log
LOG_FORMAT=json
LOG_ROTATION=10 days
LOG_RETENTION=30 days

# ========== 缓存 ==========
CACHE_ENABLED=true
CACHE_DIR=./data/cache
CACHE_DEFAULT_TTL=3600

# ========== 上传 ==========
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
MAX_FILE_SIZE=52428800
ALLOWED_FILE_TYPES=xlsx,xls,csv,pdf,jpg,jpeg,png,doc,docx,pptx

# ========== 加密 ==========
USE_ENCRYPTED_SECRETS=False
ENCRYPTION_BACKEND=aes256
ENCRYPTION_KEY_DERIVATION=pbkdf2

# ========== 监控 ==========
METRICS_ENABLED=true
METRICS_PORT=9090
HEALTH_CHECK_ENABLED=true
SLOW_QUERY_THRESHOLD_MS=200

# ========== 迁移 ==========
ENABLE_AUTO_MIGRATION=False

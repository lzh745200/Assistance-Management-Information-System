[MASTER]
# 使用多进程加速
jobs=4
# 忽略的文件或目录
ignore=CVS,.git,__pycache__,alembic,tests
# 加载的插件
load-plugins=pylint.extensions.docparams,pylint.extensions.mccabe

[MESSAGES CONTROL]
# 禁用的检查（根据项目实际情况调整）
disable=
    C0111,  # missing-docstring
    C0103,  # invalid-name
    R0903,  # too-few-public-methods
    R0913,  # too-many-arguments
    W0212,  # protected-access
    W0511,  # fixme
    C0301,  # line-too-long (由 black 处理)

[FORMAT]
# 最大行长度
max-line-length=120
# 缩进字符串
indent-string='    '

[DESIGN]
# 最大参数数量
max-args=7
# 最大局部变量数量
max-locals=20
# 最大返回语句数量
max-returns=6
# 最大分支数量
max-branches=15
# 最大语句数量
max-statements=60
# 最大属性数量
max-attributes=10
# 最小公共方法数量
min-public-methods=1
# 最大公共方法数量
max-public-methods=25
# 最大复杂度
max-complexity=15

[SIMILARITIES]
# 最小相似行数
min-similarity-lines=6
# 忽略注释
ignore-comments=yes
# 忽略文档字符串
ignore-docstrings=yes
# 忽略导入
ignore-imports=yes

[TYPECHECK]
# 忽略的模块
ignored-modules=sqlalchemy,pydantic

[REPORTS]
# 输出格式
output-format=colorized
# 报告
reports=yes
# 评分
score=yes

{
  "app_name": "帮扶管理信息系统",
  "app_name_en": "assistance-management-information-system",
  "version": "1.2.0",
  "platforms": ["windows", "linux-arm64", "kylin-arm64"],
  "output_dir": "dist",
  "backend_entry": "backend/start.py",
  "frontend_build_dir": "frontend/dist",
  "electron_dir": "electron",
  "resources_dir": "resources",
  "installers_dir": "installers",
  "build_scripts_dir": "build-scripts",
  "python_version": "3.11",
  "node_version": ">=18",
  "compression": "lzma",
  "windows": {
    "arch": "x64",
    "installer_type": "nsis",
    "vc_redist": true
  },
  "linux_arm64": {
    "arch": "arm64",
    "target": "kylin-v10",
    "package_type": "deb"
  }
}

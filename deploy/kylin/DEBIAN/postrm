#!/bin/bash
# ═══════════════════════════════════════════════════════════════
#  帮扶管理信息系统 - DEB 卸载后脚本 (postrm)
#  在 dpkg -r 或 dpkg --purge 完成后执行
# ═══════════════════════════════════════════════════════════════
set -e

APP_NAME="assistance-management-system"
DATA_DIR="/var/lib/${APP_NAME}"
LOG_DIR="/var/log/${APP_NAME}"

# 仅在 purge 模式下清除用户数据
if [ "$1" = "purge" ]; then
    echo ""
    echo "正在清除帮扶管理信息系统的所有数据..."

    # 备份提示
    if [ -d "${DATA_DIR}/database" ] && [ "$(ls -A ${DATA_DIR}/database 2>/dev/null)" ]; then
        BACKUP_FILE="/tmp/${APP_NAME}_data_backup_$(date +%Y%m%d_%H%M%S).tar.gz"
        echo "  正在备份数据到: ${BACKUP_FILE}"
        tar -czf "${BACKUP_FILE}" -C "$(dirname ${DATA_DIR})" "$(basename ${DATA_DIR})" 2>/dev/null || true
        echo "  数据已备份: ${BACKUP_FILE}"
    fi

    # 删除数据目录
    rm -rf "${DATA_DIR}"
    echo "  数据目录已删除: ${DATA_DIR}"

    # 删除日志目录
    rm -rf "${LOG_DIR}"
    echo "  日志目录已删除: ${LOG_DIR}"

    # 删除系统用户
    if getent passwd ${APP_NAME} > /dev/null 2>&1; then
        userdel ${APP_NAME} 2>/dev/null || true
        echo "  系统用户已删除: ${APP_NAME}"
    fi

    if getent group ${APP_NAME} > /dev/null 2>&1; then
        groupdel ${APP_NAME} 2>/dev/null || true
        echo "  系统组已删除: ${APP_NAME}"
    fi

    echo ""
    echo "所有数据已清除完成"
else
    # 普通卸载（dpkg -r）保留数据
    echo ""
    echo "注意: 用户数据已保留"
    echo "  数据目录: ${DATA_DIR}"
    echo "  日志目录: ${LOG_DIR}"
    echo "  如需完全清除，请运行: sudo dpkg --purge ${APP_NAME}"
fi

# 更新桌面数据库
update-desktop-database /usr/share/applications/ 2>/dev/null || true
gtk-update-icon-cache /usr/share/icons/hicolor/ 2>/dev/null || true

exit 0

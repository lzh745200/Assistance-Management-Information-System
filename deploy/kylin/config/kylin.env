# ═══════════════════════════════════════════════════════════════
#  帮扶管理信息系统 - 麒麟 V10 ARM64 专用配置
#  此文件由 systemd EnvironmentFile 加载
# ═══════════════════════════════════════════════════════════════

# ── 运行环境 ──
ENV=production
HOST=127.0.0.1
PORT=8000
DEBUG=false

# ── 麒麟模式 ──
# 启动时自动打开系统浏览器（桌面模式启用，服务器模式设为 false）
KYLIN_MODE=true
AUTO_OPEN_BROWSER=true

# ── 数据库 ──
DATABASE_URL=sqlite:////var/lib/assistance-management-system/database/rural_revitalization.db

# ── 数据目录 ──
UPLOAD_DIR=/var/lib/assistance-management-system/uploads
EXPORT_DIR=/var/lib/assistance-management-system/exports
CACHE_DIR=/var/lib/assistance-management-system/cache
BACKUP_DIR=/var/lib/assistance-management-system/backups

# ── 日志 ──
LOG_DIR=/var/log/assistance-management-system
LOG_FILE=/var/log/assistance-management-system/app.log
LOG_LEVEL=INFO

# ── 前端静态文件路径 ──
FRONTEND_DIST_PATH=/opt/assistance-management-system/frontend

# ── 安全配置（单机版延长有效期，减少频繁登录） ──
ACCESS_TOKEN_EXPIRE_MINUTES=2880
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── CORS（仅允许本机回环地址） ──
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# ── 默认管理员 ──
DEFAULT_ADMIN_USERNAME=admin
# DEFAULT_ADMIN_PASSWORD=  # 留空则自动生成随机强密码，首次启动时打印到日志

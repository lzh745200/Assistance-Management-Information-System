%% 帮扶管理信息系统 — Windows 离线安装包打包系统类图
%% 架构师：高见远

classDiagram
    direction LR

    %% ===== 构建配置层 =====
    class BuildConfig {
        <<package.json build 段>>
        +String appId
        +String productName
        +String outputDir
        +List~String~ files
        +List~ExtraResource~ extraResources
        +NsisConfig nsis
        +WinConfig win
    }

    class NsisConfig {
        +Boolean oneClick
        +Boolean perMachine
        +Boolean allowToChangeInstallationDirectory
        +String include
        +String installerIcon
        +String shortcutName
        +Boolean createDesktopShortcut
        +Boolean createStartMenuShortcut
        +Boolean deleteAppDataOnUninstall
    }

    class WinConfig {
        +List~String~ target
        +String icon
    }

    class ExtraResource {
        +String from
        +String to
        +List~String~ filter
    }

    %% ===== PyInstaller 打包层 =====
    class PyInstallerSpec {
        <<backend/assistance-backend.spec>>
        +String entryScript start.py
        +List~Tuple~ datas
        +List~String~ hiddenimports
        +List~String~ excludes
        +Boolean console False
        +Boolean upx False
        +String outputName assistance-backend
        +build() Analysis
        +build() PYZ
        +build() EXE
    }

    class BackendExe {
        <<PyInstaller 产物>>
        +String name assistance-backend.exe
        +Number sizeMB ~85
        +String arch x64 | x86
        +String pythonVersion 3.11
        +List~String~ bundledDeps
        +Boolean frozen True
        +String meipass _MEIPASS 临时目录
    }

    class StartPy {
        <<backend/start.py>>
        +main() void
        +_check_python_arch() void
        +_check_vcruntime() void
        +_ensure_dirs() void
        +_check_database_integrity() void
        +_verify_frontend_assets() void
    }

    %% ===== 前端构建层 =====
    class FrontendDist {
        <<vite build 产物>>
        +String path frontend/dist/
        +String entry index.html
        +List~String~ assets js,css,fonts,images
    }

    %% ===== Electron 层 =====
    class ElectronMainProcess {
        <<electron/main.js>>
        +getBackendExePath() String
        +getFrontendPath() String
        +getDatabasePath() String
        +getUserDataPath() String
        +getResourcePath(segments) String
        +startBackend(stderrCapture) Process
        +stopBackend() Promise
        +waitForBackend(stderrCapture) Promise
        +findAvailablePort(port, maxAttempts) Number
        +createMainWindow() void
        +createTray() void
    }

    class PreloadScript {
        <<electron/preload.js>>
        +exposeElectronAPI() void
        +getAppVersion() Promise
        +getPlatform() Promise
        +windowMinimize() void
        +windowMaximize() void
        +windowClose() void
    }

    %% ===== 打包工具层 =====
    class ElectronBuilder {
        <<打包工具 electron-builder>>
        +build(config, arch) NsisInstaller
        +downloadElectron(arch) void
        +copyExtraResources() void
        +packageAsar() void
        +generateNsisScript() void
        +compileNsis() void
    }

    class NsisHook {
        <<electron-builder-nsis-hook.nsh>>
        +installVcredist(arch) void
        +killRunningProcesses() void
        +cleanupOnUninstall() void
        +writeRegistry() void
    }

    %% ===== 最终产物 =====
    class NsisInstaller {
        <<最终安装包>>
        +String fileName 帮扶管理系统-Setup-1.2.0.exe
        +String arch x64 | x86
        +Number sizeMB ~250
        +install() void
        +uninstall() void
    }

    class VcredistBundle {
        <<resources/vcredist/>>
        +String x64File vc_redist.x64.exe
        +String x86File vc_redist.x86.exe
        +silentInstall(arch) Number
    }

    %% ===== CI/CD 层 =====
    class GitHubActionsWorkflow {
        <<.github/workflows/build-windows.yml>>
        +List~String~ triggers
        +Matrix matrix
        +List~Step~ steps
        +run() void
    }

    class Matrix {
        +List~MatrixEntry~ include
    }

    class MatrixEntry {
        +String arch x64 | x86
        +String condaArch x64 | x86
        +String ebArch x64 | ia32
    }

    class BuildJob {
        +String arch
        +Number timeoutMinutes 90
        +setupNode() void
        +setupConda(arch) void
        +installCondaDeps() void
        +buildFrontend() FrontendDist
        +buildBackend() BackendExe
        +buildInstaller() NsisInstaller
        +uploadArtifact() void
        +createRelease() void
    }

    %% ===== 运行时数据层 =====
    class PathResolver {
        <<backend/app/utils/paths.py>>
        +is_bundled() Boolean
        +get_app_data_dir() Path
        +get_database_path() Path
        +get_data_path(subPath) Path
        +get_cache_path(subPath) Path
        +get_uploads_path(subPath) Path
        +get_log_path(subPath) Path
    }

    class AppConfig {
        <<backend/app/core/config.py>>
        +String DATABASE_URL
        +String HOST
        +int PORT
        +String UPLOAD_DIR
        +String LOG_FILE
        +String ENVIRONMENT
        +model_post_init() void
    }

    %% ===== 关系 =====
    BuildConfig *-- NsisConfig
    BuildConfig *-- WinConfig
    BuildConfig *-- ExtraResource
    BuildConfig ..> PyInstallerSpec : references output name

    PyInstallerSpec ..> StartPy : entry script
    PyInstallerSpec --> BackendExe : produces

    ElectronMainProcess ..> BackendExe : spawn at runtime
    ElectronMainProcess ..> FrontendDist : loadURL via backend
    ElectronMainProcess ..> PathResolver : delegates data paths
    ElectronMainProcess *-- PreloadScript

    ElectronBuilder ..> BuildConfig : reads configuration
    ElectronBuilder ..> BackendExe : packages via extraResources
    ElectronBuilder ..> FrontendDist : packages via extraResources
    ElectronBuilder ..> VcredistBundle : includes via extraResources
    ElectronBuilder --> NsisInstaller : produces
    NsisConfig *-- NsisHook : include directive
    NsisHook ..> VcredistBundle : silent install

    GitHubActionsWorkflow *-- Matrix
    Matrix *-- MatrixEntry
    GitHubActionsWorkflow *-- BuildJob : matrix spawns
    BuildJob ..> ElectronBuilder : invokes step 12
    BuildJob ..> PyInstallerSpec : invokes step 9
    BuildJob ..> FrontendDist : produces step 6

    PathResolver ..> AppConfig : provides defaults
    BackendExe ..> PathResolver : uses when frozen
    BackendExe ..> AppConfig : reads env vars
    NsisInstaller ..> ElectronMainProcess : contains
    NsisInstaller ..> BackendExe : contains
    NsisInstaller ..> FrontendDist : contains

# 帮扶管理信息系统 - 前端环境变量配置
# 复制此文件为 .env 或 .env.development / .env.production 使用

# ==================== API 配置 ====================
# 后端 API 基础地址（单机版留空使用相对路径，开发时指向代理）
VITE_API_BASE_URL=
# WebSocket 基础 URL（留空则从 window.location 动态推断）
VITE_WS_BASE_URL=

# ==================== 应用配置 ====================
# 应用标题
VITE_APP_TITLE=帮扶管理信息系统
# 应用版本号
VITE_APP_VERSION=1.4.2
# 应用模式（standalone=单机离线, server=联网服务）
VITE_APP_MODE=standalone

# ==================== 调试配置 ====================
# 是否启用调试模式
VITE_DEBUG=false
# 是否启用性能监控
VITE_ENABLE_PERFORMANCE_MONITOR=false
# 是否启用错误追踪
VITE_ENABLE_ERROR_TRACKING=true

# ==================== 网络配置 ====================
# 请求超时时间（毫秒）
VITE_REQUEST_TIMEOUT=30000

# ==================== 认证配置 ====================
# Token 存储键名
VITE_TOKEN_KEY=auth_token
# Refresh Token 存储键名
VITE_REFRESH_TOKEN_KEY=refresh_token
# Token 刷新阈值（分钟，剩余有效期低于此值时自动刷新）
VITE_TOKEN_REFRESH_THRESHOLD=30

# ==================== 功能开关 ====================
# 是否启用 CSRF 保护
VITE_CSRF_ENABLED=true
# 是否启用离线模式（无后端时使用 Mock 数据）
VITE_OFFLINE_MODE=false

# ==================== 地图配置（离线地图） ====================
# 离线瓦片目录路径
VITE_MAP_TILE_DIR=./public/tiles
# 默认地图中心坐标（经度,纬度）
VITE_MAP_CENTER=107.518871,26.259379
# 默认缩放级别
VITE_MAP_ZOOM=9

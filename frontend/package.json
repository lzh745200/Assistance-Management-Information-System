{
  "name": "assistance-management-information-frontend",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "帮扶管理信息系统 - 前端 (Assistance Management Information System)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:check": "vue-tsc --noEmit && vite build",
    "build:only": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.ts,.tsx --fix",
    "lint:check": "eslint src --ext .vue,.ts,.tsx",
    "type-check": "vue-tsc --noEmit",
    "prepare": "cd .. && python scripts/pre_commit_hooks.py install 2>nul || true"
  },
  "lint-staged": {
    "*.{vue,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "axios": "^1.6.7",
    "chart.js": "^4.4.1",
    "dayjs": "^1.11.10",
    "dompurify": "^3.2.4",
    "driver.js": "^1.3.1",
    "echarts": "^6.1.0",
    "element-plus": "^2.6.1",
    "pinia": "^2.1.7",
    "sortablejs": "^1.15.2",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.1/xlsx-0.20.1.tgz"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.3",
    "@commitlint/config-conventional": "^19.0.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.19",
    "@types/sortablejs": "^1.15.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^2.1.9",
    "@vue/eslint-config-prettier": "^8.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "@vue/test-utils": "^2.4.4",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-vue": "^9.21.1",
    "fast-check": "^4.8.0",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.2",
    "prettier": "^3.2.5",
    "rollup": "^4.60.4",
    "sass": "^1.101.0",
    "terser": "^5.27.2",
    "typescript": "~5.3.3",
    "unplugin-auto-import": "^0.17.5",
    "unplugin-vue-components": "^0.26.0",
    "vite": "^5.4.21",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^2.1.9",
    "vue-tsc": "^2.0.6"
  }
}
